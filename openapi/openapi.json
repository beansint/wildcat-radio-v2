  "info": {
    "title": "Wildcat Radio v2 API",
    "description": "Control plane — see docs/final-build-plan/03-API-CONTRACT.md",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "SubmitQueueItemDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "REQUEST",
              "DEDICATION",
              "QUESTION"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "recipient": {
            "type": "string",
            "maxLength": 120
          }
        },
        "required": [
          "type",
          "text"
        ]
      },
      "QueueSubmissionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Queue item id (cuid)"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING"
            ]
          },
          "remaining": {
            "type": "number",
            "description": "Remaining queue submissions available to this listener for the episode"
          }
        },
        "required": [
          "id",
          "status",
          "remaining"
        ]
      },
      "PollOptionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Poll option id (cuid)"
          },
          "text": {
            "type": "string"
          },
          "voteCount": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "text",
          "voteCount"
        ]
      },
      "PollResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Poll id (cuid)"
          },
          "question": {
            "type": "string"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "PUBLIC",
              "ANONYMOUS"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "totalVotes": {
            "type": "number"
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PollOptionResponseDto"
            }
          }
        },
        "required": [
          "id",
          "question",
          "visibility",
          "isActive",
          "totalVotes",
          "options"
        ]
      },
      "VotePollDto": {
        "type": "object",
        "properties": {
          "optionId": {
            "type": "string",
            "description": "Poll option id (cuid)"
          }
        },
        "required": [
          "optionId"
        ]
      },
      "CreateReactionDto": {
        "type": "object",
        "properties": {
          "emoji": {
            "type": "string",
            "enum": [
              "🔥",
              "❤️",
              "😂",
              "👏"
            ]
          }
        },
        "required": [
          "emoji"
        ]
      },
      "ReactionResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "ok"
        ]
      },
      "EngagementUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User id (cuid)"
          },
          "handle": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "handle",
          "name"
        ]
      },
      "StudioQueueItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Queue item id (cuid)"
          },
          "episodeId": {
            "type": "string",
            "description": "Episode id (cuid)"
          },
          "submitterId": {
            "type": "string",
            "description": "Submitting user id (cuid)"
          },
          "type": {
            "type": "string",
            "enum": [
              "REQUEST",
              "DEDICATION",
              "QUESTION"
            ]
          },
          "text": {
            "type": "string"
          },
          "recipient": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "QUEUED",
              "READ",
              "DECLINED",
              "EXPIRED",
              "REMOVED"
            ]
          },
          "actedById": {
            "type": "string",
            "nullable": true
          },
          "actedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "submitter": {
            "$ref": "#/components/schemas/EngagementUserResponseDto"
          }
        },
        "required": [
          "id",
          "episodeId",
          "submitterId",
          "type",
          "text",
          "recipient",
          "status",
          "actedById",
          "actedAt",
          "createdAt",
          "submitter"
        ]
      },
      "StudioQueueResponseDto": {
        "type": "object",
        "properties": {
          "episodeId": {
            "type": "string",
            "description": "Active episode id (cuid)"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StudioQueueItemResponseDto"
            }
          }
        },
        "required": [
          "episodeId",
          "items"
        ]
      },
      "QueueActDto": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "QUEUE",
              "READ",
              "DECLINE"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "QueueActionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Queue item id (cuid)"
          },
          "status": {
            "type": "string",
            "enum": [
              "QUEUED",
              "READ",
              "DECLINED"
            ]
          },
          "receipt": {
            "type": "boolean",
            "description": "Whether a private queue receipt is emitted to the submitter"
          }
        },
        "required": [
          "id",
          "status",
          "receipt"
        ]
      },
      "CreatePollDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "options": {
            "minItems": 2,
            "maxItems": 6,
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "visibility": {
            "type": "string",
            "enum": [
              "PUBLIC",
              "ANONYMOUS"
            ],
            "default": "PUBLIC"
          }
        },
        "required": [
          "question",
          "options"
        ]
      },
      "PinTopicDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 280
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "text"
        ]
      },
      "PinnedTopicResponseDto": {
        "type": "object",
        "properties": {
          "episodeId": {
            "type": "string",
            "description": "Active episode id (cuid)"
          },
          "text": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "episodeId",
          "text",
          "expiresAt"
        ]
      },
      "BoothChatDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "required": [
          "content"
        ]
      },
      "ChatMessageResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Chat message id (cuid)"
          },
          "episodeId": {
            "type": "string",
            "description": "Active episode id (cuid)"
          },
          "content": {
            "type": "string"
          },
          "asBooth": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/EngagementUserResponseDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "episodeId",
          "content",
          "asBooth",
          "createdAt",
          "author"
        ]
      }
    }
  }
}
